      "string_list": "round_0\nround_1\nround_2\nround_3",
      "json_list": "[]",
      "int_range_start": 0,
      "int_range_end": 0,
      "int_range_step": 1,
      "float_range_start": 0.0,
      "float_range_end": 0.0,
      "float_range_step": 0.1,
      "int_decrement_total": 5,
